APP_NAME=RHMatch
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rhmatch
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# =====================================================
# GROQ AI — obrigatório pra geração de JD e match
# Pegue sua chave em: https://console.groq.com/keys
# =====================================================
GROQ_API_KEY=gsk_COLOQUE_SUA_CHAVE_AQUI

# =====================================================
# STORAGE — IMPORTANTE para a logo funcionar
# Disco padrão para uploads públicos (logo, currículos)
# NUNCA use "local" aqui — usa "public" pra ter acesso via web
# =====================================================
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@rhmatch.com.br"
MAIL_FROM_NAME="${APP_NAME}"
